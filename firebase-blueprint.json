{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User configuration containing baseline stats",
      "type": "object",
      "properties": {
        "monthlyIncome": { "type": "number" },
        "targetDailyExpense": { "type": "number" },
        "targetSavings": { "type": "number" },
        "characterName": { "type": "string" },
        "avatar": { "type": "string" },
        "gender": { "type": "string" },
        "customHPCap": { "type": "number" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["monthlyIncome", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction Record",
      "description": "A financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Gain", "Expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "rune": { "type": "string" },
        "timestamp": { "type": "timestamp" }
      },
      "required": ["type", "amount", "category", "rune", "timestamp"]
    },
    "ScheduledEvent": {
      "title": "Scheduled Event",
      "description": "Recurring transaction or bounty",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Toll", "Bounty"] },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "rune": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "frequencyValue": { "type": "number" },
        "autoLog": { "type": "boolean" },
        "nextDueDate": { "type": "timestamp" },
        "lastLoggedAt": { "type": "timestamp" }
      },
      "required": ["type", "name", "amount", "category", "rune", "frequency", "autoLog", "nextDueDate"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile documents"
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User transaction history"
    },
    "users/{userId}/scheduledEvents/{eventId}": {
      "schema": { "$ref": "#/entities/ScheduledEvent" },
      "description": "Recurring Scheduled Events"
    }
  }
}
